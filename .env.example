# Runtime
OUTPUT_DIR=./output
AUTO_CLUSTER_THRESHOLD=0.90
REVIEW_THRESHOLD=0.50
ALLOW_PARENT_FAMILY_TAX_CONFLICTS=true
KNOWN_BRAND_FAMILIES_FILE=data/known_brand_families.csv
KNOWN_BRAND_FAMILY_DEFAULT_CONFIDENCE=76.0
LEGAL_KEYWORDS_FILE=data/legal_keywords.csv
GENERIC_NON_BRIDGE_FILE=data/generic_non_bridge_keywords.csv
# Optional JSON or comma list, e.g.
# SUPPORT_FIELD_STRENGTHS={"canonical_name":"family_or_parent","CompanyEntityId":"same_entity_id"}
SUPPORT_FIELD_STRENGTHS=

# Backend LLM review. Do not put real keys in source control.
AI_REVIEW_ENABLED=false
AI_PROVIDER=openai_compatible
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
GEMINI_API_KEY=
GOOGLE_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
AI_MODEL=gpt-5.5
LLM_MODEL=gpt-5.5
LLM_ENABLED=false
LLM_SEND_SCOPE=all_review_candidates
ALLOW_UNRESOLVED_LLM_CANDIDATES_IN_FINAL_OUTPUT=false
LLM_EXECUTION_MODE=disabled
MAX_LLM_GROUPS_PER_JOB=0
MAX_ROWS_PER_LLM_GROUP=60
MAX_TOKENS_PER_LLM_GROUP=6000
MAX_TOTAL_LLM_COST_PER_JOB=0
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_COUNT=2
OVERRIDE_LLM_CAN_MODIFY_98=false
# Required before live LLM mode for meaningful cost estimates.
# Cost estimate is UNKNOWN, not free, when these are blank/zero.
# If MAX_TOTAL_LLM_COST_PER_JOB is set and pricing is missing, live mode
# blocks unless ALLOW_UNKNOWN_LLM_COST=true.
OPENAI_INPUT_COST_PER_1M_TOKENS=
OPENAI_OUTPUT_COST_PER_1M_TOKENS=
ALLOW_UNKNOWN_LLM_COST=false

# Optional OpenAI-compatible fallback
# AI_PROVIDER=openai_compatible
# OPENAI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-5.1

# Optional Claude fallback
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-sonnet-4-5

# Optional Gemini fallback
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# LLM_MODEL=gemini-2.5-flash

# Large-file and AI uncertain grouping controls
MAX_TOTAL_CANDIDATE_PAIRS=1000000
MAX_WEAK_BLOCK_SIZE=300
EXACT_TAX_STAR_THRESHOLD=100
MAX_EXACT_TAX_ONLY_BLOCK_SIZE=10
MAX_EXACT_TAX_DISTINCT_ROOTS=3
MAX_WEAK_REVIEW_CLUSTER_SIZE=50
MAX_LOW_CONFIDENCE_CLUSTER_SIZE=6
MAX_KNOWN_FAMILY_CLUSTER_SIZE=25
MAX_KNOWN_BRAND_FAMILY_BLOCK_SIZE=300
AI_UNCERTAIN_CLUSTER_ENABLED=true
AI_UNCERTAIN_MATCH_PCT=68.0
AI_MAX_CALLS=50
AI_CACHE_ENABLED=true
AI_CACHE_PATH=.cache/llm_review_cache.json
LLM_CAN_AUTO_CLUSTER=false
RARE_TOKEN_MAX_DOCUMENT_FRACTION=0.03
RARE_TOKEN_MIN_DOCUMENT_FREQUENCY=1
